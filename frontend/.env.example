NEXT_PUBLIC_API_URL=https://seu-backend.railway.app
NEXT_PUBLIC_SITE_URL=https://agentes-ai-two.vercel.app

# Checkout Pix manual
NEXT_PUBLIC_PIX_KEY=configure-sua-chave-pix@empresa.com
NEXT_PUBLIC_PIX_NAME=Agentes AI
NEXT_PUBLIC_PIX_BANK=Pix manual

# Mercado Pago (opcional; quando configurado, /checkout pode gerar link externo)
MP_ACCESS_TOKEN=APP_USR_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR_xxxxxxxxxxxxxxxxxxxxx

# Banco usado pelas rotas server-side do frontend na Vercel
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_SSL=true

# IA operacional
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# Sprint 8 — integrações e canais
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
CRM_WEBHOOK_URL=
RESEND_API_KEY=
EMAIL_FROM=
WEBHOOK_SIGNING_SECRET=

# Sprint 10 — operação assistida e envio externo
ENABLE_EXTERNAL_SEND=false
CUSTOM_OUTBOUND_WEBHOOK_URL=
OPERATION_DEFAULT_REVIEWER=Operador Agentes AI
OPERATION_SLA_DEFAULT_MINUTES=45
OPERATION_SLA_HIGH_MINUTES=20
OPERATION_SLA_CRITICAL_MINUTES=10
